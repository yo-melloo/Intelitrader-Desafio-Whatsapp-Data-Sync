<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <!-- Define a versão do .NET. 
         Em Java, seria como o <java.version> no pom.xml -->
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- StackExchange.Redis é a biblioteca padrão para Redis em C#.
         Equivalente ao Jedis/Lettuce no Java ou redis-py no Python. -->
    <PackageReference Include="StackExchange.Redis" Version="2.7.33" />
  </ItemGroup>

</Project>
